[user]
    name = {{ git_user_name }}
{% if git_email_result is defined and git_email_result.stdout is defined %}
    email = {{ git_email_result.stdout }}
{% endif %}
{% if git_signing and git_signing_key_result is defined and git_signing_key_result.stdout is defined %}
    signingkey = {{ git_signing_key_result.stdout }}
{% endif %}

[init]
    defaultBranch = {{ git_default_branch }}

[core]
    editor = {{ git_editor }}
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

[pull]
    rebase = false

{% if git_signing %}
[gpg]
    format = ssh

[gpg "ssh"]
{% if ansible_host_environment_is_wsl | default(false) | bool %}
    program = /mnt/c/Program Files/1Password/app/8/op-ssh-sign-wsl.exe
{% else %}
    program = /opt/1Password/op-ssh-sign
{% endif %}

[commit]
    gpgsign = true
{% endif %}

[includeIf "gitdir:~/work/"]
    path = ~/work/.gitconfig
