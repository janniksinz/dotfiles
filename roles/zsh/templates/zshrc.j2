# Managed by Ansible - zsh role
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="robbyrussell"

plugins=({{ zsh_omz_plugins | join(' ') }} zsh-autosuggestions zsh-syntax-highlighting)

source $ZSH/oh-my-zsh.sh

# Dedup-safe PATH helper
addToPath() {
    if [[ "$PATH" != *"$1"* ]]; then
        export PATH="$PATH:$1"
    fi
}

# PATH
{% for p in zsh_extra_paths %}
addToPath "{{ p }}"
{% endfor %}

# Environment
export XDG_CONFIG_HOME="$HOME/.config"
export EDITOR=nvim
export VISUAL=nvim

# fnm (fast node manager)
eval "$(fnm env --use-on-cd --shell zsh)"

# zoxide (smart cd)
eval "$(zoxide init zsh)"

# Conda
__conda_setup="$('{{ user_home }}/miniconda3/bin/conda' 'shell.zsh' 'hook' 2>/dev/null)"
if [ $? -eq 0 ]; then
    eval "$__conda_setup"
elif [ -f "{{ user_home }}/miniconda3/etc/profile.d/conda.sh" ]; then
    . "{{ user_home }}/miniconda3/etc/profile.d/conda.sh"
else
    addToPath "{{ user_home }}/miniconda3/bin"
fi
unset __conda_setup

# Aliases
alias ll='lsd -la'
alias ls='lsd'
alias cat='bat --paging=never'
alias cd='z'
alias vim='nvim'
